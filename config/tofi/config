# vim:fileencoding=utf-8:filetype=cfg:foldmethod=marker
# Tofi Configuration

# Font {{{
font = "/usr/share/fonts/TTF/FiraCodeNerdFont-Retina.ttf"
font-size = 14
hint-font = false
# }}}

# Text and Color {{{
# Default color
text-color = #aaaaaa
background-color = #121212
border-color = #c7704d
outline-color = #121212

# Prompt to display
prompt-text = "Search: "
prompt-color = #d6d6d6
prompt-background = #121212

# Placeholder text
placeholder-text = "Type to filter"
placeholder-color = #636363
placeholder-background = #121212

# Input text
#input-color = #aaaaaa
#input-background = #121212

# Default (odd-numbered) result text
default-result-color = #aaaaaa
default-result-background = #121212
default-result-background-padding = 0,-1

# Alternate (even-numbered) result text
alternate-result-color = #aaaaaa
alternate-result-background = #1c1c1c
alternate-result-background-padding = 0,-1

# Selection text
selection-color = #d6d6d6
selection-background = #2d2d2d
selection-background-padding = 0,-1

# Matching portion of selection text
selection-match-color = #ed4a46
# }}}

# Window {{{
width = 30%
height = 28%

outline-width = 0
border-width = 2

padding-top = 2
padding-bottom = 2
padding-left = 2
padding-right = 2

anchor = center
#exclusive-zone = 0
#margin-top = 0
#margin-bottom = 0
#margin-left = 0
#margin-right = 0
# }}}

# Output {{{
num-results = 16
result-spacing = 1
ascii-input = true
# }}}

fuzzy-match = true

require-match = true

auto-accept-single = false

hide-input = false
